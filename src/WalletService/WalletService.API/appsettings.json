{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Loki": {
      "Uri": "http://loki:3100"
    }
  },
  "AllowedHosts": "*",
  "Firestore": {
    "ProjectId": "",
    "CredentialsPath": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "savesafe-auth",
    "Audience": "savesafe-clients"
  },
  "InternalApi": {
    "ApiKey": ""
  }

  ,"Kafka": {
    "BootstrapServers": "kafka:29092",
    "ProducerAcks": "All",
    "ConsumerGroupId": "wallet-service-consumer",
    "AutoOffsetReset": "Earliest",
    "EnableAutoCommit": false,
    "MaxRetryAttempts": 3
  }
}
