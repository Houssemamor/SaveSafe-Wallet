# Copy this file to .env and fill in values before running docker compose
# NEVER commit .env to version control

# Redis
REDIS_PASSWORD=ssw_redis_secret

# JWT (must be at least 32 characters for HS256)
JWT_SECRET_KEY=change-this-to-a-secure-random-secret-min32chars

# Internal service-to-service API key
INTERNAL_API_KEY=change-this-internal-key

# Default admin bootstrap account (created only if no admin exists)
DEFAULT_ADMIN_EMAIL=admin@savesafe.local
DEFAULT_ADMIN_NAME=Default Administrator
DEFAULT_ADMIN_PASSWORD=Admin@12345!

# Firestore (backend)
FIRESTORE_PROJECT_ID=your-project-id
FIRESTORE_CREDENTIALS_PATH=./secrets/firebase.json

# Firebase Web API key (frontend)
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000